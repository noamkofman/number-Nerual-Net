{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "shell",
            "label": "Run main",
            "command": "/usr/bin/clang++ -g -std=c++17 '${workspaceFolder}/main.cpp' -o '${workspaceFolder}/.vscode/main_debug' -L'/usr/local/opt/raylib/lib' -I'/usr/local/opt/raylib/include' -lraylib -framework OpenGL -framework Cocoa -framework IOKit -framework CoreVideo && '${workspaceFolder}/.vscode/main_debug'",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "focus": true,
                "clear": true,
                "showReuseMessage": false
            },
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}
